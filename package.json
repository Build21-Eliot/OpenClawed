{
  "name": "openclaw-claude-code-adapter",
  "version": "1.0.0",
  "description": "OpenAI-compatible HTTP bridge from OpenClaw to Claude Code CLI (claude -p)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclaw-claude-code-adapter": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src --ext .ts",
    "prettier:fix": "prettier --write \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "typescript-eslint": "^8.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
